  "paleontology": {
    "summary": "Deinosuchus is a giant alligatoroid crocodylian from the Late Cretaceous of North America (and related forms are debated globally). It is famous for unusually deep, enlarged teeth and a broad rostrum suited to overpowering large prey in coastal rivers and estuaries.",
    "size": "Scientific length estimates vary widely by method; many rigorous discussions land nearer ~8–10 m for credible specimens, with flashier ‘15 m’ claims relying on fragmentary extrapolation.",
    "fossilRecord": "Iconic teeth and skull elements document Campanian coastal exposures along the Western Interior Seaway; scattered records anchor it as a top predator in nearshore ecosystems.",
    "papers": [
      {
        "cite": "Schwimmer, D. R. (2002). King of the Crocodilians: The Paleobiology of Deinosuchus. Indiana University Press.",
        "note": "Foundational pop-science + technical blend."
      },
      {
        "cite": "Brochu, C. A. (1997). Systematics and relationships of Alligatoroidea.",
        "note": "Phylogenetic framing for Deinosuchus among alligatoroids."
      },
      {
        "cite": "Cossette & Brochu (2020) — crocodylian macroevolution work revisiting species concepts.",
        "note": "Shows taxonomy still in motion; contrast with in-game ‘subspecies’ names."
      }
    ],
    "collections": [
      "See Western Interior Seaway halls in major U.S. natural history museums for context fossils and casts."
    ]
  }
}
